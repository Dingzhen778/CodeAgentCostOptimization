# ============================================================
# LLM API Keys（在 .env 中填入真实值，不要提交到 git）
# ============================================================

# Anthropic / Claude（通过中转站接入）
ANTHROPIC_AUTH_TOKEN=your_anthropic_token_here
ANTHROPIC_BASE_URL=https://your-proxy.api.com/model-api

# OpenAI-compatible 中转站（推荐用于低成本实验）
OPENAI_API_KEY=your_openai_compatible_key_here
OPENAI_BASE_URL=https://your-proxy.api.com/v1

# DeepSeek（廉价高性能）
DEEPSEEK_API_KEY=your_deepseek_key_here

# Qwen（阿里云百炼）
QWEN_API_KEY=your_qwen_key_here

# OpenRouter（统一中转，按 token 计费）
OPENROUTER_API_KEY=your_openrouter_key_here

# GLM（智谱 AI）
GLM_API_KEY=your_glm_key_here

# ============================================================
# Gateway 配置
# ============================================================
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8080
GATEWAY_LOG_LEVEL=INFO

# ============================================================
# 实验配置
# ============================================================
EXPERIMENT_OUTPUT_DIR=./experiments
LOG_DIR=./logs
MAX_CONCURRENT_INSTANCES=4
